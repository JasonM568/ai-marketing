# 共用 Supabase (supabase-huibang)
POSTGRES_URL=postgresql://postgres.xxx:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# JWT Secret (與官網後台相同)
JWT_SECRET=your-jwt-secret-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Supabase Storage (品牌參考資料檔案上傳)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# Meta (Facebook / Instagram / Threads)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://your-domain.com/api/social/meta/callback

# Token 加密 (32+ 字元隨機字串)
TOKEN_ENCRYPTION_KEY=your-random-encryption-key-at-least-32-chars

# Vercel Cron Secret
CRON_SECRET=your-cron-secret

# 綠界 ECPay
ECPAY_MERCHANT_ID=your-merchant-id
ECPAY_HASH_KEY=your-hash-key
ECPAY_HASH_IV=your-hash-iv
ECPAY_API_URL=https://payment-stage.ecpay.com.tw
